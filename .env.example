# Environment variables — copy this file to .env and fill in the values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# Email provider — set emailProvider in src/lib/config.ts to switch.
# Default is 'resend'.
# ------------------------------------------------------------------

# === Resend (emailProvider: 'resend') =============================
# Your Resend API key. Get one at https://resend.com/api-keys
RESEND_API_KEY=re_...

# === SMTP (emailProvider: 'smtp') =================================
# Also run: pnpm add nodemailer
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=secret
# SMTP_SECURE=false   # set to 'true' for port 465 / implicit TLS

# ------------------------------------------------------------------
# Envelope overrides — if not set, the values in src/lib/config.ts
# are used. These work regardless of which provider is active.
# ------------------------------------------------------------------
# CONTACT_EMAIL_TO=you@yourdomain.com
# CONTACT_EMAIL_FROM=My Site <noreply@yourdomain.com>
